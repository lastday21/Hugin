HUGIN_ENVIRONMENT=development
HUGIN_API_HOST=127.0.0.1
HUGIN_API_PORT=8000
HUGIN_LOG_LEVEL=INFO
HUGIN_DOCKER_PORT=8010
HUGIN_DATABASE_HOST=127.0.0.1
HUGIN_DATABASE_PORT=5432
HUGIN_DATABASE_NAME=hugin
HUGIN_DATABASE_USER=hugin
HUGIN_DATABASE_PASSWORD=replace-with-a-long-random-password
HUGIN_POSTGRES_PORT=5432
HUGIN_HH_BROWSER_TIMEOUT_MS=60000
HUGIN_HH_APPLY_DAILY_LIMIT=25
HUGIN_HH_APPLY_DELAY_MIN_SECONDS=30
HUGIN_HH_APPLY_DELAY_MAX_SECONDS=60
